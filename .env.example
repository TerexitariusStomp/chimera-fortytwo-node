# Chimera Testnet Configuration
CHIMERA_RPC_URL=http://localhost:8545
CHIMERA_CHAIN_ID=31337
CHIMERA_WS_URL=ws://localhost:8545

# Node Operator Wallet
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Coordinator
COORDINATOR_WS_URL=ws://localhost:8080
COORDINATOR_HTTP_URL=http://localhost:8080

# Node Configuration
NODE_NAME=chimera-fortytwo-node-01
NODE_REGION=us-east
NODE_CAPACITY_TOKENS_PER_SEC=50
NODE_MIN_PRICE_WEI=1000000000000
NODE_STAKE_WEI=1000000000000000000

# Model Configuration
MODEL_CACHE_DIR=./models/cache
DEFAULT_MODEL=phi-3-mini-4k-instruct
MODEL_FORMAT=onnx

# Inference Backend (onnx | python | mock)
INFERENCE_BACKEND=mock
PYTHON_INFERENCE_URL=http://localhost:5000

# Consensus
CONSENSUS_MIN_PEERS=3
CONSENSUS_MATCH_TIMEOUT_MS=30000
RANKING_WINDOW_SIZE=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Optional: Sentry / Observability
SENTRY_DSN=
